{
  "name": "vetrina-foto",
  "version": "1.0.0",
  "private": true,
  "description": "Vetrina fotografica con selezione, gallery web e export per stampa",
  "scripts": {
    "import": "node scripts/import-photos.js",
    "import:scan": "node scripts/import-photos.js --scan",
    "import:update": "node scripts/import-photos.js --update",
    "amazon:sync": "node scripts/amazon-photos-sync.js",
    "amazon:verify": "node scripts/verify-amazon-photos.js",
    "family:setup": "node scripts/setup-family-refs.js",
    "family:verify": "node scripts/verify-family.js",
    "family:test": "node scripts/test-family-recognition.js",
    "optimize": "node scripts/optimize-photos.js",
    "serve": "npx --yes serve public -l 3000"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "canvas": "^3.2.3",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=20"
  }
}
